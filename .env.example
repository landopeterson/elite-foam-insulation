# Copy to .env and fill in real values. NEVER commit .env.

# --- Supabase ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service role key (server-side only — bypasses RLS; keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# --- Email notifications (where contact-form leads are sent) ---
# Using Resend (https://resend.com) — free tier is plenty for a small business.
RESEND_API_KEY=
# Address leads are emailed TO (the business owner)
LEAD_NOTIFY_TO=
# Verified "from" address Resend sends as (e.g. leads@yourdomain.com)
LEAD_NOTIFY_FROM=

# --- CORS ---
# The deployed frontend origin (and http://localhost:5173 etc. in dev)
FRONTEND_ORIGIN=http://localhost:5173
